# Backend Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/fruitytrack

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# AI Service
AI_SERVICE_URL=http://localhost:5001

# Frontend URLs
FRONTEND_URL=http://localhost:3000
MOBILE_API_URL=http://localhost:5000

# Logging
DEBUG=false

# Kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=fruitytrack-backend
KAFKA_TOPIC_PREFIX=fruitytrack

# Alert Consumer
ALERT_CONSUMER_ENABLED=true
ALERT_CONSUMER_GROUP_ID=fruitytrack-alert-consumer
ALERT_MIN_LEVEL=warning
ALERT_COOLDOWN_SECONDS=120
ALERT_RULE_MAX_AI_MS=2000
ALERT_RULE_MAX_PROCESSING_MS=5000

# Email Alerts (SMTP)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=noreply@fruitytrack.local
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Webhook Alerts
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_AUTH_HEADER=
ALERT_WEBHOOK_TIMEOUT_MS=5000
